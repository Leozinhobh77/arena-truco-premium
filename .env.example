# Exemplo de variáveis de ambiente — Arena Truco Premium
# Copie este arquivo para .env.local e preencha com seus valores do Supabase
# NUNCA suba o .env.local para o Git (já está no .gitignore)

# Encontre em: supabase.com → seu projeto → Settings → API
VITE_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...SUA_ANON_KEY_AQUI

# Para Netlify: configure essas mesmas variáveis em:
# Site Settings → Environment Variables
